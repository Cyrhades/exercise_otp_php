{
    "name": "yoop/skeleton",
    "type": "project",
    "license": "MIT",
    "description": "Squelette pour création d'une web application avec Yoop",
    "minimum-stability": "dev",
    "autoload" : {
        "psr-4" : {
            "App\\" : "src/"     
        }
    },
    "repositories":[
        {
            "type": "package",
            "package": {
                "name": "cyrhades/yoop",
                "version" : "master",
                "source": {
                    "url": "https://github.com/Cyrhades/yoop.git",
                    "type": "git",
                    "reference": "master"
                },
                "autoload": {
                    "psr-4": { "Yoop\\": ["src/"] }
                }
            }
      
        }
    ],
    "require": {
        "cyrhades/yoop": "master",
        "twig/twig": "^3.0",
        "nikic/fast-route": "^1.3",
        "robthree/twofactorauth": "dev-master",
        "vlucas/phpdotenv": "^5.6@dev",
        "endroid/qr-code": "^6.0@dev"
    },
    "require-dev": {
        "symfony/var-dumper": "^5.1"
    }
}
